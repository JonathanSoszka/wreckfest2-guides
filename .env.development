# Local dev overrides (astro dev only — production builds ignore this file).
# Committed on purpose: these are non-secret authoring conveniences, not config.
#
# Flags default to OFF so production can never ship an unfinished section by
# accident; you turn them on here to keep working on them locally.

# Racing Lessons section is gated off in production while it's being reviewed.
FEATURE_LESSONS=false

# Show `draft: true` guides while authoring.
SHOW_DRAFTS=true
