---
import BaseLayout from '../../layouts/BaseLayout.astro';

/**
 * Tuning cheat sheet: every in-game slider mapped to what moving it does.
 *
 * Two views of one dataset, per the design review:
 *  - a symptom → fix band (FIXES) that answers "the car does X, what do I change";
 *  - an opposed table (GROUPS) with the two ends' effects side by side, which is
 *    the fastest way to look up one setting.
 *
 * Grounded in src/data/tuning/surface-tuning-reference.md and the game's real
 * slider set (src/data/tuning/schema.ts). In the table, `left`/`right` are the
 * effects of the slider's LEFT (lower/looser/open/soft) and RIGHT
 * (higher/grippier/locked/stiff) ends — kept short so the row stays scannable;
 * the fuller reasoning lives in the reference. Where the reference doesn't cover
 * a slider (Front Balancer, Ackermann, Wedge) the row says so via `note`.
 *
 * `favor` maps a track condition to the end that suits it ('l' or 'r'), from the
 * reference's category directions. A condition absent from a setting's `favor` =
 * no honest lean: that row dims and is tagged when the condition is selected.
 */
const CONDITIONS = ['loose', 'grippy', 'bumpy', 'straights', 'tight'] as const;
type Condition = (typeof CONDITIONS)[number];

/**
 * Drivetrain. The game shows one universal menu label ("Differential — Rear")
 * for every car, but the slider controls whichever axle drives — so locking it
 * adds oversteer on RWD and understeer on FWD (surface-tuning-reference.md,
 * "diff by axle"). Copy that flips between drivetrains is a `Variant`; both are
 * rendered and the toggle shows one. Plain strings are drivetrain-neutral.
 */
type Drivetrain = 'rwd' | 'fwd';
type Variant = string | Record<Drivetrain, string>;

interface Setting {
  name: string;
  qualifier?: string; // small note under the name, e.g. "accel lock"
  ends: [string, string]; // [left, right]
  left: Variant; // effect of the left/min end (short)
  right: Variant; // effect of the right/max end (short)
  note?: Variant; // caveat spanning the row
  favor?: Partial<Record<Condition, 'l' | 'r'>>;
}
interface Group {
  category: string;
  blurb?: Variant;
  settings: Setting[];
}

// Grouped into a handful of functional areas rather than the game's 13 menu
// categories, so the reference is easier to scan. Each row keeps its in-game
// menu name (e.g. "Differential · Power") so it still maps back to the tuning
// screen. `qualifier` is the small text under the name.
const GROUPS: Group[] = [
  {
    category: 'Braking',
    settings: [
      { favor: { grippy: 'r' }, name: 'Brake Balance', ends: ['Rear', 'Front'],
        left: 'Rotates the car on the brakes; too far and the rear locks and spins.',
        right: 'Stabler stops — the front locks first, which is safe and easy to feel; too far and it washes wide.' },
      { favor: { loose: 'l', grippy: 'r', bumpy: 'l' }, name: 'Brake Pressure', ends: ['Low', 'High'],
        left: 'Harder to lock up — the safety net for dirt and gravel.',
        right: 'Shorter stops where there is grip.' },
      { name: 'Front Balancer', ends: ['Off', 'On'],
        left: 'Test it off.', right: 'Test it on.',
        note: 'An unlabelled front assist with no documented rule. Try both ways in one braking zone and keep whichever feels better.' },
    ],
  },
  {
    category: 'Drivetrain',
    blurb: {
      rwd: 'The diff acts on the rear axle: more locked on the loose (traction), more open on grip (turn-in). Locking it adds oversteer. Gearing ends are outcomes, not numbers.',
      fwd: 'The diff acts on the front axle: more locked on the loose (traction), more open on grip (turn-in). Locking it adds understeer — the opposite of RWD. Gearing ends are outcomes, not numbers.',
    },
    settings: [
      { favor: { loose: 'r', grippy: 'l' }, name: 'Differential · Power', qualifier: 'accel lock · driven axle', ends: ['Open', 'Locked'],
        left: {
          rwd: 'Frees turn-in on grip; on the loose it just spins the unloaded wheel.',
          fwd: 'Lets the front wheels turn at their own speeds, so it fights your steering less; on the loose it just spins the unloaded wheel.',
        },
        right: {
          rwd: 'Both rear wheels drive together for traction out of corners; understeers on entry and can snap on exit on tarmac.',
          fwd: 'Both front wheels pull together for traction, but it pushes the nose wide under power and tugs at the steering.',
        },
        note: {
          rwd: 'The game labels this "Differential — Rear" for every car; on a rear-driver that is literally the rear axle.',
          fwd: 'The game still labels this "Differential — Rear", but on a front-driver it controls the front axle — so locking it pushes the nose rather than stepping the tail out.',
        } },
      { favor: { loose: 'r', grippy: 'l' }, name: 'Differential · Coast', qualifier: 'decel lock · driven axle', ends: ['Open', 'Locked'],
        left: {
          rwd: 'Less understeer while slowing on tarmac; a livelier rear when you lift.',
          fwd: 'Frees the rear to swing on a lift — the rotation you actually want on entry.',
        },
        right: {
          rwd: 'Steadies the rear under braking and lift on the loose.',
          fwd: 'Calms the car under braking, but blunts the lift-off rotation a front-driver leans on to turn in.',
        } },
      { favor: { loose: 'r', grippy: 'l' }, name: 'Differential · Preload', qualifier: 'driven axle', ends: ['Open', 'Locked'],
        left: {
          rwd: 'Less mid-corner understeer on grip.',
          fwd: 'Less power-on push; lets the front wheels differentiate mid-corner.',
        },
        right: {
          rwd: 'Mid-corner traction and stability on the loose.',
          fwd: 'Mid-corner traction on the loose, at the cost of more nose-push.',
        } },
      { favor: { loose: 'r', grippy: 'l', straights: 'l', tight: 'r' }, name: 'Final Drive', ends: ['Top speed', 'Acceleration'],
        left: 'Taller gearing — higher top end, lazier pull. Suits fast, open tarmac.',
        right: 'Quicker off the line and out of corners, lower top speed. Suits tight, technical, loose tracks.' },
      { favor: { loose: 'r', grippy: 'l', straights: 'l', tight: 'r' }, name: 'Forward Gears', qualifier: 'each gear', ends: ['Top speed', 'Acceleration'],
        left: 'A longer gear carrying more speed, with fewer shifts.',
        right: 'A shorter gear with more pull that revs out sooner.' },
    ],
  },
  {
    category: 'Suspension',
    blurb: 'Stiffen an end and it loses grip — that is the lever for balance.',
    settings: [
      { favor: { loose: 'l', grippy: 'r', bumpy: 'l' }, name: 'Springs · Front', ends: ['Soft', 'Stiff'],
        left: 'More front grip and compliance over rough or loose ground.',
        right: 'Sharper on smooth tarmac, but less front grip (understeer) and it skips over bumps.' },
      { favor: { loose: 'l', grippy: 'r', bumpy: 'l' }, name: 'Springs · Rear', ends: ['Soft', 'Stiff'],
        left: 'More rear traction and a calmer tail.',
        right: 'Rotates the car — less rear grip means oversteer.' },
      { favor: { loose: 'r', grippy: 'l', bumpy: 'r' }, name: 'Ride Height', qualifier: 'front / rear', ends: ['Low', 'High'],
        left: 'Lower centre of gravity — tarmac stability and response; bottoms out on rough ground.',
        right: 'Clears ruts and crests and pushes the tyre to the hard base; more roll, less tarmac stability.' },
      { favor: { loose: 'l', grippy: 'r', bumpy: 'l' }, name: 'Anti-roll Bar · Front', ends: ['Soft', 'Stiff'],
        left: 'More front mechanical grip over bumps.',
        right: 'Less roll and sharper on grip, but reduces front grip (understeer) and transmits bumps.' },
      { favor: { loose: 'l', grippy: 'r', bumpy: 'l' }, name: 'Anti-roll Bar · Rear', ends: ['Soft', 'Stiff'],
        left: 'More rear grip and stability.',
        right: 'Rotates the car — reduces rear grip for oversteer.' },
    ],
  },
  {
    category: 'Alignment',
    settings: [
      { favor: { loose: 'r', grippy: 'l' }, name: 'Camber', qualifier: 'front / rear', ends: ['Neg', 'Pos'],
        left: 'More negative — grip in sustained high-load cornering, which tarmac rewards.',
        right: 'Less negative — a flatter contact patch for braking and acceleration, which the loose wants.' },
      { favor: { loose: 'r', grippy: 'l' }, name: 'Toe', qualifier: 'front / rear', ends: ['Out', 'In'],
        left: 'Toe-out — sharper, more eager turn-in, but twitchier and it scrubs speed.',
        right: 'Toe-in — straight-line stability; a little on the rear settles the car on the loose.' },
      { favor: { straights: 'l', tight: 'r' }, name: 'Ackermann', ends: ['None', 'Full'],
        left: 'Biased toward faster, more open corners.',
        right: 'Biased toward tight, low-speed corners.',
        note: 'How much more the inside front wheel steers than the outside. Not covered by the surface reference — the ideal depends on the track, not the surface.' },
    ],
  },
  {
    category: 'Steering & balance',
    blurb: 'Mostly preference, not lap-time-critical.',
    settings: [
      { favor: { loose: 'r', tight: 'r' }, name: 'Steering · Lock to Lock', ends: ['Low', 'High'],
        left: 'Less steering lock.',
        right: 'More lock — bigger counter-steer angles for holding slides on the loose.',
        note: 'On a gamepad, Lock to Lock behaves as the readout shows.' },
      { favor: { tight: 'r' }, name: 'Steering · Ratio', ends: ['Low', 'High'],
        left: 'Slower steering response.', right: 'Quicker steering response.',
        note: 'On a gamepad, set this one notch slower than shown.' },
      { name: 'Wedge', qualifier: 'oversteer bias', ends: ['Left', 'Right'],
        left: 'Left cross-weight bias.', right: 'Right cross-weight bias.',
        note: 'Cross-weight shifts static load diagonally. Undocumented in this game — named "Oversteer Bias" in-game, but its exact effect here is untested.' },
    ],
  },
];

/** Symptom → fix: the inverse index. `dir` drives the badge: + stiffen/lock/raise, − soften/open/lower, ~ technique. */
interface Fix {
  problem: string;
  items: { dir: '+' | '-' | '~'; text: string }[];
  /** Shown only for this drivetrain — some failure modes are drivetrain-specific. */
  only?: Drivetrain;
}
const FIXES: Fix[] = [
  { problem: 'Understeers on entry', items: [
    { dir: '-', text: 'Soften the front springs or ARB' },
    { dir: '+', text: 'Stiffen the rear' },
    { dir: '+', text: 'A touch more front brake bias' },
    { dir: '-', text: 'A little front toe-out' },
  ]},
  { problem: 'Snappy / oversteers on entry', items: [
    { dir: '+', text: 'Stiffen the front, or soften the rear' },
    { dir: '+', text: 'More locked coast diff' },
    { dir: '-', text: 'Less rear toe-out' },
  ]},
  { problem: 'Won’t rotate mid-corner', items: [
    { dir: '+', text: 'Stiffer rear ARB or springs' },
    { dir: '-', text: 'Open the power diff a touch (grip)' },
    { dir: '-', text: 'Lower the preload' },
  ]},
  { problem: 'Spins under power on the loose', only: 'rwd', items: [
    { dir: '+', text: 'Lock the power diff more' },
    { dir: '+', text: 'More preload' },
    { dir: '~', text: 'Ease the throttle — technique' },
  ]},
  // The FWD signature problem (car-reference.md): the front tyres steer, brake and
  // drive, so the enemy is power-on understeer. The fix is to rotate before power,
  // not to lock the diff harder.
  { problem: 'Pushes wide on power (FWD)', only: 'fwd', items: [
    { dir: '+', text: 'Stiffen the rear ARB or springs to rotate earlier' },
    { dir: '-', text: 'A little rear toe-out' },
    { dir: '-', text: 'Open the power diff a touch' },
    { dir: '~', text: 'Get it turned before you get on the throttle' },
  ]},
  { problem: 'Won’t turn in (FWD)', only: 'fwd', items: [
    { dir: '-', text: 'Open the coast diff — keep the lift-off rotation' },
    { dir: '+', text: 'Stiffen the rear' },
    { dir: '~', text: 'Lift or trail-brake to bring the tail round' },
  ]},
  { problem: 'Locks the wheels braking on loose', items: [
    { dir: '-', text: 'Lower the brake pressure' },
    { dir: '~', text: 'Check the balance isn’t too far rear' },
  ]},
  { problem: 'Skittish / bottoms out on rough', items: [
    { dir: '+', text: 'Raise the ride height' },
    { dir: '-', text: 'Soften the springs' },
  ]},
  { problem: 'Slow onto the straights', items: [
    { dir: '+', text: 'Shorten the final drive (toward Acceleration)' },
  ]},
  { problem: 'Hits the limiter on straights', items: [
    { dir: '-', text: 'Lengthen the final drive (toward Top speed)' },
  ]},
];

/**
 * How settings interact — cross-setting relationships, since sliders don't act
 * alone. Grounded in surface-tuning-reference.md ("How settings interact").
 * `flag` marks the honesty caveat colour: 'warn' for the rake/aero and wedge
 * cases that barely apply in an arcade game.
 */
interface Interaction { title: string; body: string; flag?: 'warn'; }
const INTERACTIONS: Interaction[] = [
  { title: 'Balance is the front-vs-rear difference',
    body: 'Understeer/oversteer is set by the ratio of front-to-rear stiffness, not how stiff the car is overall — and springs and bars pool into one number per axle. Same result two ways: stiffen the rear or soften the front both add oversteer.' },
  { title: 'Bars for balance, springs for bumps',
    body: 'Both add roll stiffness, but a spring reacts to every bump while a bar reacts only in roll. On loose ground, carry cornering balance on the anti-roll bars and keep springs softer for compliance — but a very stiff bar ties the two wheels, so a one-wheel rut upsets the whole axle.' },
  { title: 'Ride height pairs with spring rate',
    body: 'Lower drops the centre of gravity and shrinks all weight transfer — a bigger grip win than limiting roll — but it costs travel, so it needs stiffer springs to avoid bottoming. On rough tracks don’t slam it: keep travel for the ruts and match springs to the height.' },
  { title: 'Brake balance shifts with weight',
    body: 'Braking throws weight forward, so a front-biased split is normal (50/50 locks the rears first). A softer rear or a higher car dives more and effectively wants a touch more front brake. Rear steps out on entry → move balance forward; nose ploughs → move it back.' },
  { title: 'Camber and toe are splits too',
    body: 'More negative front camber than rear frees the nose; more rear than front plants the tail. Rear toe-in calms a loose rear (exit understeer), rear toe-out frees it. Set balance with the camber split first, then fine-tune with toe — toe scrubs speed, so keep it small.' },
  { title: 'Preload is the floor under power & coast',
    body: 'Preload is the always-on baseline lock; the power and coast ramps build beyond it. More preload means the diff is calmer, more locked and slower to react everywhere; less frees rotation but is twitchier. Set preload first, then the two ramps.' },
  { title: 'Final drive is the master, gears are the gaps',
    body: 'Final drive scales every gear at once — set it so you just hit redline in top at the end of the longest straight — then space the individual gears so the ones you use most sit in the engine’s strong rev band. It’s the product (final × gear) that counts.' },
  { title: 'Rake barely applies here', flag: 'warn',
    body: 'Rear-higher-than-front is an aero tool in the games it’s famous for, and Wreckfest has no aero. Strip that away and only a subtle forward weight nudge remains, which an arcade engine may not model. Don’t chase rake for balance — treat front/rear ride height as a small weight-bias tweak and use springs and bars instead.' },
  { title: 'Keep wedge near 50%', flag: 'warn',
    body: 'Cross-weight is a diagonal adjustment (raising one corner loads it and its diagonal opposite), so off-centre wedge just makes the car handle differently left vs right. Only worth moving on a dedicated one-way oval; on tracks that turn both ways, leave it neutral.' },
];
---
<BaseLayout
  title="Tuning Cheat Sheet"
  description="Every Wreckfest 2 tuning slider mapped to what moving it does, plus a quick symptom-to-fix guide."
>
  <p class="eyebrow">Tuning</p>
  <h1>Tuning cheat sheet</h1>
  <p class="lead">
    What every slider does, and what to change when the car misbehaves. Start with the fixes if you
    have a specific problem; drop into the table to look up a single setting.
  </p>

  <div class="cs-dt-scope" data-dt="rwd" id="dt-scope">
  <div class="cs-dt-bar" role="group" aria-label="Drivetrain">
    <span class="cs-flabel">Drivetrain</span>
    <button type="button" class="cs-chip is-on" data-dt-set="rwd" aria-pressed="true">RWD</button>
    <button type="button" class="cs-chip" data-dt-set="fwd" aria-pressed="false">FWD</button>
    <span class="cs-dt-hint">
      <span class="dt-only" data-dt="rwd">13 of the 18 cars</span>
      <span class="dt-only" data-dt="fwd">5 of the 18 cars — the diff and the fixes below invert</span>
    </span>
  </div>

  <div class="callout cs-rule">
    <p>
      <strong>The one rule that covers half of this:</strong> stiffen an end and it loses grip.
      A stiffer front (spring or bar) adds understeer; a stiffer rear adds oversteer. Soften the end
      you want to calm down, or stiffen the end you want to free up.
      <span class="dt-only" data-dt="fwd">
        On a front-driver that rule reads inverted in practice: the front tyres steer, brake
        <em>and</em> drive, so you stiffen the <strong>rear</strong> to make the nose turn.
      </span>
    </p>
  </div>

  <section id="fixes" class="cs-fixes-wrap">
    <div class="cs-sechead">
      <h2>Fix it fast</h2>
      <p class="cs-legend">
        <span class="badge up">+</span> stiffen / lock / raise &nbsp;·&nbsp;
        <span class="badge dn">−</span> soften / open / lower &nbsp;·&nbsp;
        <span class="badge tech">~</span> technique
      </p>
    </div>
    <div class="cs-fixes">
      {FIXES.map((f) => (
        <div class:list={['fix-card', f.only && 'dt-only']} data-dt={f.only}>
          <h3>{f.problem}</h3>
          <ul>
            {f.items.map((i) => (
              <li>
                <span class:list={['badge', i.dir === '+' ? 'up' : i.dir === '-' ? 'dn' : 'tech']}>
                  {i.dir === '+' ? '+' : i.dir === '-' ? '−' : '~'}
                </span>{i.text}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="cs-table-wrap" id="settings">
    <div class="cs-sechead">
      <h2>Every setting</h2>
      <p class="cs-legend">
        <span class="dn">←</span> lower / looser end &nbsp;·&nbsp; higher / grippier end <span class="up">→</span>
      </p>
    </div>

    <div class="cs-filters" aria-label="Bias the sheet for a track condition">
      <span class="cs-flabel">Bias for</span>
      <button type="button" class="cs-chip is-on" data-cond="all" aria-pressed="true">All</button>
      <button type="button" class="cs-chip" data-cond="loose" aria-pressed="false">Loose</button>
      <button type="button" class="cs-chip" data-cond="grippy" aria-pressed="false">Grippy</button>
      <button type="button" class="cs-chip" data-cond="bumpy" aria-pressed="false">Bumpy</button>
      <button type="button" class="cs-chip" data-cond="straights" aria-pressed="false">Long Straights</button>
      <button type="button" class="cs-chip" data-cond="tight" aria-pressed="false">Tight Turns</button>
    </div>
    <p class="cs-fcap" id="cs-fcap" role="status" aria-live="polite"></p>

    {GROUPS.map((group) => (
      <div class="cs-group">
        <div class="cs-grouphead">
          <h3>{group.category}</h3>
          {group.blurb && (typeof group.blurb === 'string'
            ? <span class="cs-blurb">{group.blurb}</span>
            : <>
                <span class="cs-blurb dt-only" data-dt="rwd">{group.blurb.rwd}</span>
                <span class="cs-blurb dt-only" data-dt="fwd">{group.blurb.fwd}</span>
              </>)}
        </div>
        <div class="cs-scroll">
          <table class="cs-tbl">
            <thead>
              <tr>
                <th class="th-name">Setting</th>
                <th class="th-l">← lower / looser</th>
                <th class="th-r">higher / grippier →</th>
              </tr>
            </thead>
            <tbody>
              {group.settings.map((s) => (
                <>
                  <tr class="cs-row" data-favor={JSON.stringify(s.favor ?? {})}>
                    <td class="td-name">
                      {s.name}
                      {s.qualifier && <small>{s.qualifier}</small>}
                    </td>
                    <td class="td-eff" data-end="l">
                      <span class="end end-l">{s.ends[0]}</span>{' '}
                      {typeof s.left === 'string' ? s.left : <>
                        <span class="dt-only" data-dt="rwd">{s.left.rwd}</span>
                        <span class="dt-only" data-dt="fwd">{s.left.fwd}</span>
                      </>}
                    </td>
                    <td class="td-eff" data-end="r">
                      <span class="end end-r">{s.ends[1]}</span>{' '}
                      {typeof s.right === 'string' ? s.right : <>
                        <span class="dt-only" data-dt="rwd">{s.right.rwd}</span>
                        <span class="dt-only" data-dt="fwd">{s.right.fwd}</span>
                      </>}
                    </td>
                  </tr>
                  {s.note && (
                    <tr class="tr-note"><td colspan="3">
                      {typeof s.note === 'string' ? s.note : <>
                        <span class="dt-only" data-dt="rwd">{s.note.rwd}</span>
                        <span class="dt-only" data-dt="fwd">{s.note.fwd}</span>
                      </>}
                    </td></tr>
                  )}
                </>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    ))}
  </section>

  <section class="cs-interactions">
    <div class="cs-sechead">
      <h2>How settings work together</h2>
      <p class="cs-legend">Sliders don't act alone — the useful stuff is in the relationships.</p>
    </div>
    <div class="cs-inter-grid">
      {INTERACTIONS.map((it) => (
        <div class:list={['inter-card', it.flag === 'warn' && 'is-warn']}>
          <h3>{it.title}</h3>
          <p>{it.body}</p>
        </div>
      ))}
    </div>
  </section>

  </div>

  <p class="lead cs-foot">
    Grounded in the site's <a href="/tuning/">tuning reference</a>. Percentages elsewhere describe
    position along a slider's travel, since Wreckfest's readouts can exceed 100%.
  </p>
</BaseLayout>

<script>
  // Drivetrain toggle: both RWD and FWD copy is in the HTML; this flips which one
  // the scope shows. The differential is the reason it exists — the game uses one
  // "Differential — Rear" label for every car, but it drives whichever axle powers
  // the car, so locking it adds oversteer on RWD and understeer on FWD.
  const dtScope = document.getElementById('dt-scope');
  const dtBar = dtScope?.querySelector<HTMLElement>('.cs-dt-bar');

  dtBar?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-dt-set]');
    if (!btn || !dtScope) return;
    const dt = btn.dataset.dtSet!;
    dtScope.setAttribute('data-dt', dt);
    dtBar.querySelectorAll<HTMLButtonElement>('[data-dt-set]').forEach((b) => {
      const on = b === btn;
      b.classList.toggle('is-on', on);
      b.setAttribute('aria-pressed', String(on));
    });
    try { localStorage.setItem('wf2:cheat-drivetrain', dt); } catch {}
  });

  // Restore the last choice so a front-drive player isn't re-picking every visit.
  try {
    const saved = localStorage.getItem('wf2:cheat-drivetrain');
    if (saved === 'fwd' || saved === 'rwd') {
      dtBar?.querySelector<HTMLButtonElement>(`[data-dt-set="${saved}"]`)?.click();
    }
  } catch {}

  // Condition filter: highlight the slider end that suits the picked track condition
  // and dim the rest. Single-select; "All" clears. Rows carry a data-favor map
  // (condition -> 'l' | 'r'); a condition absent from a row = no honest lean, so
  // that row dims and gets a "no lean" tag. Only the settings table reacts.
  const CAPTIONS: Record<string, string> = {
    all: '',
    loose: 'Loose — soft springs and bars, higher ride height, a locked diff, gentler brakes.',
    grippy: 'Grippy — the mirror: stiff, low, an open diff, harder brakes, more negative camber.',
    bumpy: 'Bumpy — compliance only: soften springs and bars, raise the car, brake a touch easier.',
    straights: 'Long Straights — gear for top speed and drop Ackermann. Little else cares about a straight.',
    tight: 'Tight Turns — gear for acceleration, more steering lock, full Ackermann.',
  };

  const wrap = document.getElementById('settings');
  const bar = wrap?.querySelector<HTMLElement>('.cs-filters');
  const cap = document.getElementById('cs-fcap');
  const rows = Array.from(wrap?.querySelectorAll<HTMLElement>('.cs-row') ?? []);

  bar?.addEventListener('click', (e) => {
    const chip = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-cond]');
    if (!chip) return;
    const cond = chip.dataset.cond!;

    bar.querySelectorAll<HTMLButtonElement>('.cs-chip').forEach((c) => {
      const on = c === chip;
      c.classList.toggle('is-on', on);
      c.setAttribute('aria-pressed', String(on));
    });
    if (cap) cap.textContent = CAPTIONS[cond] ?? '';
    wrap?.classList.toggle('is-filtering', cond !== 'all');

    for (const row of rows) {
      const eff = row.querySelectorAll<HTMLElement>('.td-eff');
      eff.forEach((td) => td.classList.remove('is-hl'));
      row.classList.remove('is-dim');
      if (cond === 'all') continue;
      let favor: Record<string, string> = {};
      try { favor = JSON.parse(row.dataset.favor || '{}'); } catch {}
      const end = favor[cond];
      if (end === 'l' || end === 'r') {
        row.querySelector<HTMLElement>(`.td-eff[data-end="${end}"]`)?.classList.add('is-hl');
      } else {
        row.classList.add('is-dim');
      }
    }
  });
</script>

