---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { render } from 'astro:content';
import { getPublished } from '../../lib/content';

export async function getStaticPaths() {
  // Only the generic drivetrain guides get their own page now. Per-car setups are rendered
  // inline on each car's profile (/cars/<slug>/#setup).
  const guides = (await getPublished('tuning')).filter((t) => t.data.kind === 'generic');
  return guides.map((guide) => ({ params: { slug: guide.id }, props: { guide } }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
---
<BaseLayout title={guide.data.title} description={guide.data.summary}>
  <a href="/tuning/" class="back">← All tuning guides</a>

  {/* Every guide (generic and per-car) renders its own header inside the right-hand
      column of the setup grid — see the guide MDX. */}
  <article class="prose car-wide">
    <Content />
  </article>
</BaseLayout>
