---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const tracks = (await getCollection('tracks'))
  .filter((t) => !t.data.draft)
  .sort((a, b) => a.data.order - b.data.order || a.data.name.localeCompare(b.data.name));

const surfaces = [...new Set(tracks.map((t) => t.data.surface))].sort();
const layoutCount = (t: (typeof tracks)[number]) =>
  t.data.layouts?.length ?? (t.data.hasReverse ? 2 : 1);
---
<BaseLayout title="Track Profiles" description="Wreckfest 2 tracks: surface, layouts, and racing line notes.">
  <p class="eyebrow">Track Profiles</p>
  <h1>Tracks</h1>
  <p class="lead">Every venue in the current build — surface, layouts, and where the race is actually decided.</p>

  <div class="car-filters" aria-label="Filter tracks">
    <div class="filter-group">
      <span class="filter-label">Surface</span>
      <button type="button" class="filter-chip active" data-filter="surf:all">All</button>
      {surfaces.map((s) => (
        <button type="button" class="filter-chip" data-filter={`surf:${s}`}>{s}</button>
      ))}
    </div>
  </div>

  <div class="grid track-grid">
    {tracks.map((track) => (
      <a href={`/tracks/${track.id}/`} class="card" data-surf={track.data.surface}>
        <h3>{track.data.name}</h3>
        {track.data.location && <p class="card-meta">{track.data.location}</p>}
        <p>{track.data.summary}</p>
        <p class="tags">
          <span class={`tag tag-${track.data.surface}`}>{track.data.surface}</span>
          <span class="tag tag-plain">{layoutCount(track)} {layoutCount(track) === 1 ? 'layout' : 'layouts'}</span>
          {track.data.hasReverse && <span class="tag tag-plain">+ reverse</span>}
        </p>
      </a>
    ))}
  </div>
  <p class="lead track-empty" style="display:none;">No tracks match that filter.</p>
  {tracks.length === 0 && <p class="lead">No track profiles published yet.</p>}
</BaseLayout>

<script>
  const bar = document.querySelector<HTMLElement>('.car-filters');
  if (bar) {
    const cards = Array.from(document.querySelectorAll<HTMLElement>('.track-grid .card'));
    const empty = document.querySelector<HTMLElement>('.track-empty');
    let surf = 'all';
    bar.addEventListener('click', (e) => {
      const chip = (e.target as HTMLElement).closest<HTMLElement>('[data-filter]');
      if (!chip) return;
      surf = chip.dataset.filter!.split(':')[1];
      bar.querySelectorAll('[data-filter^="surf:"]').forEach((c) => c.classList.toggle('active', c === chip));
      let shown = 0;
      for (const card of cards) {
        const ok = surf === 'all' || card.dataset.surf === surf;
        card.style.display = ok ? '' : 'none';
        if (ok) shown++;
      }
      if (empty) empty.style.display = shown ? 'none' : '';
    });
  }
</script>
