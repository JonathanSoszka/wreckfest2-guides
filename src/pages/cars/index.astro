---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CarArt from '../../components/CarArt.astro';
import { getPublished } from '../../lib/content';

const cars = (await getPublished('cars'))
  .sort((a, b) => a.data.name.localeCompare(b.data.name));

const drivetrains = [...new Set(cars.map((c) => c.data.drivetrain))].sort();
const dtClass = (dt: string) => `tag tag-${dt.toLowerCase()}`;
---
<BaseLayout title="Car Profiles" description="Every Wreckfest 2 car: drivetrain, handling, and setup notes.">
  <p class="eyebrow">Car Profiles</p>
  <h1>Cars</h1>
  <p class="lead">How each car behaves on track, and the setup to match.</p>

  <div class="car-filters" aria-label="Filter cars">
    <div class="filter-group">
      <span class="filter-label">Drive</span>
      <button type="button" class="filter-chip active" data-filter="dt:all">All</button>
      {drivetrains.map((d) => (
        <button type="button" class="filter-chip" data-filter={`dt:${d}`}>{d}</button>
      ))}
    </div>
  </div>

  <div class="car-rows">
    {cars.map((car) => (
      <a href={`/cars/${car.id}/`} class="car-row" data-dt={car.data.drivetrain}>
        <span class="car-stage">
          <CarArt
            name={car.data.name}
            drivetrain={car.data.drivetrain}
            bodyStyle={car.data.bodyStyle}
            heroImage={car.data.heroImage}
          />
        </span>
        <span class="car-row-main">
          {car.data.inspiration && <span class="card-eyebrow">{car.data.inspiration}</span>}
          <h3>{car.data.name}</h3>
          <span class="car-row-sum">{car.data.summary}</span>
        </span>
        <span class="car-row-side">
          <span class={dtClass(car.data.drivetrain)}>{car.data.drivetrain}</span>
          {car.data.archetype && <span class="card-arch">{car.data.archetype}</span>}
        </span>
      </a>
    ))}
  </div>
  <p class="lead car-empty" style="display:none;">No cars match that filter.</p>
  {cars.length === 0 && <p class="lead">No car profiles published yet.</p>}
</BaseLayout>

<script>
  const bar = document.querySelector<HTMLElement>('.car-filters');
  if (bar) {
    const rows = Array.from(document.querySelectorAll<HTMLElement>('.car-rows .car-row'));
    const empty = document.querySelector<HTMLElement>('.car-empty');
    const state: Record<string, string> = { dt: 'all' };
    bar.addEventListener('click', (e) => {
      const chip = (e.target as HTMLElement).closest<HTMLElement>('[data-filter]');
      if (!chip) return;
      const [kind, val] = chip.dataset.filter!.split(':');
      state[kind] = val;
      bar.querySelectorAll(`[data-filter^="${kind}:"]`).forEach((c) => c.classList.toggle('active', c === chip));
      let shown = 0;
      for (const row of rows) {
        const ok = state.dt === 'all' || row.dataset.dt === state.dt;
        row.style.display = ok ? '' : 'none';
        if (ok) shown++;
      }
      if (empty) empty.style.display = shown ? 'none' : '';
    });
  }
</script>
