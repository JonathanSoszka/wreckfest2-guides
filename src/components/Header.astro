---
import { enabledSections } from '../config/flags';

const path = Astro.url.pathname;
const isActive = (base: string) =>
  base === '/' ? path === '/' : path.startsWith(base);
// Nav order and gating both come from SECTIONS — a flagged-off section drops out here
// and its routes are removed from the build entirely (see astro.config.mjs).
const links = enabledSections().map((s) => ({ href: s.href, label: s.nav }));
---
<header class="site-header">
  <div class="wrap">
    <a href="/" class="brand"><span class="mark">▛</span> Wreckfest 2 Guides</a>
    <nav class="nav">
      {links.map((l) => (
        <a href={l.href} aria-current={isActive(l.href) ? 'page' : undefined}>{l.label}</a>
      ))}
    </nav>
  </div>
</header>
